---
import Base from "../../layouts/Base.astro";
import { getTagMap } from "../../lib/tags";

export async function getStaticPaths() {
  const map = await getTagMap();
  return [...map.entries()].map(([tag, items]) => ({
    params: { tag },
    props: { tag, items },
  }));
}

const { tag, items } = Astro.props;
const kindLabel: Record<string, string> = { library: "资料库", writing: "手记" };
---
<Base title={`#${tag} · Tags`} description={`标签「${tag}」下的资料库与手记。`}>
  <section class="mx-auto max-w-3xl px-6 pt-20 pb-8">
    <p class="text-sm text-muted tracking-wider uppercase">
      <a href="/tags" class="hover:text-accent">Tags</a>
    </p>
    <h1 class="font-display mt-3 leading-tight text-ink" style="font-size: var(--text-display-xl)">
      #{tag}
    </h1>
    <p class="mt-3 text-sm text-muted">{items.length} 条相关内容</p>
  </section>

  <hr class="border-rule mx-auto max-w-3xl" />

  <section class="mx-auto max-w-3xl px-6 py-12">
    <ul class="divide-y divide-rule">
      {items.map((it) => (
        <li class="py-6 grid grid-cols-[5rem_1fr] gap-4 items-baseline">
          <span class="text-xs text-muted tracking-wider uppercase">{kindLabel[it.type]}</span>
          <div>
            <a href={it.href} class="font-display text-xl text-ink hover:text-accent leading-snug">
              {it.title}
            </a>
            <p class="mt-1 text-sm text-ink-soft leading-relaxed">{it.summary}</p>
            <p class="mt-1 text-xs text-muted tabular-nums">{it.date.toISOString().slice(0, 10)}</p>
          </div>
        </li>
      ))}
    </ul>
    <p class="mt-10 text-sm"><a href="/tags" class="text-accent hover:text-ink">← 所有标签</a></p>
  </section>
</Base>
