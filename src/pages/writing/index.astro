---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("writing", (e) => !e.data.draft))
  .sort((a, b) => +b.data.date - +a.data.date);
const pinned = posts.filter((p) => p.data.pinned);
const rest = posts.filter((p) => !p.data.pinned);
---
<Base title="Writing · Jason Ye" description="短文、读后感、小红书精选的长版本。">
  <section class="mx-auto max-w-3xl px-6 pt-20 pb-10">
    <p class="text-sm text-muted tracking-wider uppercase">Writing</p>
    <h1 class="font-display mt-3 leading-tight text-ink" style="font-size: var(--text-display-xl)">
      手记
    </h1>
    <p class="mt-4 max-w-2xl text-ink-soft leading-relaxed">
      只写我自己反复在用、能讲清来龙去脉的东西。短文为主，按时间倒序。
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-6 pb-20">
    {pinned.length > 0 && (
      <>
        <h2 class="text-xs tracking-wider uppercase text-muted mb-4 border-t border-rule pt-6">Pinned</h2>
        <ul class="divide-y divide-rule">
          {pinned.map((p) => (
            <li class="py-6">
              <a href={`/writing/${p.id}`} class="block font-display text-2xl text-ink hover:text-accent leading-snug">
                {p.data.title}
              </a>
              {p.data.subtitle && (
                <p class="mt-1 text-sm italic text-muted">{p.data.subtitle}</p>
              )}
              <p class="mt-2 text-sm text-ink-soft leading-relaxed">{p.data.summary}</p>
              <p class="mt-3 text-xs text-muted">{p.data.date.toISOString().slice(0, 10)}</p>
            </li>
          ))}
        </ul>
      </>
    )}

    {rest.length > 0 && (
      <>
        <h2 class="text-xs tracking-wider uppercase text-muted mt-10 mb-4 border-t border-rule pt-6">Latest</h2>
        <ul class="divide-y divide-rule">
          {rest.map((p) => (
            <li class="py-6 grid md:grid-cols-[7rem_1fr] gap-4">
              <p class="text-xs text-muted tabular-nums">
                {p.data.date.toISOString().slice(0, 10)}
              </p>
              <div>
                <a href={`/writing/${p.id}`} class="block font-display text-xl text-ink hover:text-accent leading-snug">
                  {p.data.title}
                </a>
                <p class="mt-1 text-sm text-ink-soft leading-relaxed">{p.data.summary}</p>
                <div class="mt-2 flex flex-wrap gap-2 text-xs text-muted">
                  {p.data.tags.map((t) => (
                    <a href={`/tags/${encodeURIComponent(t.toLowerCase())}`} class="px-2 py-0.5 border border-rule rounded-full hover:text-accent hover:border-accent transition-colors">{t}</a>
                  ))}
                </div>
              </div>
            </li>
          ))}
        </ul>
      </>
    )}

    {posts.length === 0 && (
      <p class="text-sm text-muted py-12">最近还没有文章。订阅 <a href="/rss.xml" class="text-accent hover:text-ink">RSS</a>。</p>
    )}
  </section>
</Base>
